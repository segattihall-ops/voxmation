2:T87b,[{"@context":"https://schema.org","@type":"Product","name":"Voxmation — Voice Prompt Automation","description":"Voice prompt automation platform with IVR, outbound campaigns, and AI transcription.","offers":[{"@type":"Offer","name":"Self-Hosted","price":"0","priceCurrency":"USD","availability":"https://schema.org/InStock"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is the self-hosted version really free forever?","acceptedAnswer":{"@type":"Answer","text":"Yes. Voxmation is MIT licensed. Deploy it, modify it, and use it commercially — no fee, no expiry, no feature gates. Your only cost is the infrastructure you run it on."}},{"@type":"Question","name":"Do I need Asterisk or FreeSWITCH to use Voxmation?","acceptedAnswer":{"@type":"Answer","text":"No. Voxmation works with Twilio out of the box — no PBX required. If you have Asterisk or FreeSWITCH, we integrate directly via AMI/AGI and ESL for lower per-minute costs."}},{"@type":"Question","name":"When will cloud-managed hosting be available?","acceptedAnswer":{"@type":"Answer","text":"We're building out cloud-managed infrastructure now. Join the waitlist to be notified at launch and lock in early pricing."}},{"@type":"Question","name":"What's included in the enterprise plan?","acceptedAnswer":{"@type":"Answer","text":"Dedicated infrastructure, custom SLA, SSO, white-label options, a dedicated customer success manager, and professional services. Contact our sales team for a custom quote."}},{"@type":"Question","name":"Does Voxmation mark up telephony minutes?","acceptedAnswer":{"@type":"Answer","text":"On self-hosted deployments, you pay your SIP trunk or Twilio directly — no Voxmation markup. Cloud-managed and enterprise plans include telephony at cost or with volume discounts."}},{"@type":"Question","name":"Is Voxmation HIPAA compliant?","acceptedAnswer":{"@type":"Answer","text":"Self-hosted deployments can be configured for HIPAA compliance when paired with the right infrastructure choices (encrypted storage, network controls). Cloud-managed and enterprise plans include HIPAA-eligible configuration as part of the setup."}}]}]0:["S5gZpK2z1bREN6GRhTmk5",[[["",{"children":["pricing",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["pricing",{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","section",null,{"className":"pt-16 pb-12 px-4 sm:px-6 lg:px-8 text-center","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","h1",null,{"className":"text-4xl sm:text-5xl font-extrabold text-white mb-5 tracking-tight","children":"Simple, honest pricing"}],["$","p",null,{"className":"text-xl text-gray-400","children":"Self-host for free. Scale to cloud when you're ready. Talk to us for enterprise."}]]}]}],["$","section",null,{"className":"py-12 px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 items-start","children":[["$","div",null,{"className":"border border-gray-800/60 rounded-3xl p-8 bg-gray-900/30","children":[["$","div",null,{"className":"mb-6","children":[["$","span",null,{"className":"inline-block px-3 py-1 text-xs font-semibold text-gray-400 bg-gray-800 rounded-full mb-4","children":"Self-Hosted"}],["$","div",null,{"className":"flex items-baseline gap-1 mb-1","children":[["$","span",null,{"className":"text-5xl font-black text-white","children":"$$0"}],["$","span",null,{"className":"text-gray-500 text-sm","children":"/ forever"}]]}],["$","p",null,{"className":"text-gray-500 text-sm","children":"MIT License. Deploy on your own infrastructure."}]]}],["$","a",null,{"href":"https://github.com/voxmation/voxmation","target":"_blank","rel":"noopener noreferrer","className":"flex items-center justify-center gap-2 w-full py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-colors mb-8","children":["D