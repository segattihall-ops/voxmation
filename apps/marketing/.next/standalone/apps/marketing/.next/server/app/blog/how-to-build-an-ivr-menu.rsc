0:["S5gZpK2z1bREN6GRhTmk5",[[["",{"children":["blog",{"children":[["slug","how-to-build-an-ivr-menu","d"],{"children":["__PAGE__?{\"slug\":\"how-to-build-an-ivr-menu\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","how-to-build-an-ivr-menu","d"],{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"How to Build an IVR Menu in 2025 (Asterisk, FreeSWITCH, and Twilio)\",\"description\":\"A practical guide to building IVR menus from scratch — covering dialplan design, prompt recording, DTMF handling, speech recognition, and integration with your CRM or help desk.\",\"datePublished\":\"2025-03-25\",\"author\":{\"@type\":\"Organization\",\"name\":\"Voxmation\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Voxmation\",\"url\":\"https://voxmation.com\"},\"url\":\"https://voxmation.com/blog/how-to-build-an-ivr-menu\",\"image\":\"https://voxmation.com/og-image.png\"}"}}],["$","article",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16","children":[["$","$L2",null,{"href":"/blog","className":"inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-300 transition-colors mb-8","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Back to Blog"]}],["$","header",null,{"className":"mb-10","children":[["$","div",null,{"className":"flex flex-wrap items-center gap-4 mb-4","children":[["$","div",null,{"className":"flex items-center gap-1.5 text-sm text-gray-600","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar w-4 h-4","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],"March 25, 2025"]}],["$","div",null,{"className":"flex items-center gap-1.5 text-sm text-gray-600","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","polyline","68esgv",{"points":"12 6 12 12 16 14"}],"$undefined"]}],"12 min read"]}],["$","div",null,{"className":"flex items-center gap-1.5 text-sm text-gray-600","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-user w-4 h-4","children":[["$","path","975kel",{"d":"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"}],["$","circle","17ys0d",{"cx":"12","cy":"7","r":"4"}],"$undefined"]}],"Voxmation Team"]}]]}],["$","h1",null,{"className":"text-3xl sm:text-4xl font-extrabold text-white leading-tight mb-4","children":"How to Build an IVR Menu in 2025 (Asterisk, FreeSWITCH, and Twilio)"}],["$","p",null,{"className":"text-lg text-gray-400 leading-relaxed","children":"A practical guide to building IVR menus from scratch — covering dialplan design, prompt recording, DTMF handling, speech recognition, and integration with your CRM or help desk."}]]}],["$","div",null,{"className":"prose-custom","children":[["$","h2","0",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"How to Build an IVR Menu in 2025"}],["$","div","1",{"className":"h-2"}],["$","p","2",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"An IVR (Interactive Voice Response) menu is the front door of your phone system. Done well, it routes callers to the right place quickly. Done poorly, it drives customers to hang up."}}],["$","div","3",{"className":"h-2"}],["$","p","4",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"This guide covers how to build a production-grade IVR from scratch using Asterisk, FreeSWITCH, or Twilio — including the common mistakes that make IVRs frustrating."}}],["$","div","5",{"className":"h-2"}],["$","h2","6",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"IVR Design Principles Before You Write a Line of Code"}],["$","div","7",{"className":"h-2"}],["$","p","8",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Before touching configuration, get your call flow on paper:"}}],["$","div","9",{"className":"h-2"}],["$","p","10",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"1. <strong class='text-gray-200'>Map the customer intent, not your org chart</strong> — Don't build the menu around your departments. Build it around why customers call. \"Track my order\" is better than \"Operations department.\""}}],["$","p","11",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"2. <strong class='text-gray-200'>Keep menus shallow</strong> — Maximum 4–5 options per level. Maximum 2 levels deep. Callers don't remember option 6."}}],["$","p","12",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"3. <strong class='text-gray-200'>Always offer escape routes</strong> — \"Press 0 for an agent\" should be available at every level."}}],["$","p","13",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"4. <strong class='text-gray-200'>Read options before the key</strong> — Say \"For billing, press 2\" not \"Press 2 for billing.\" Callers listen for their intent, then remember the key."}}],["$","p","14",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"5. <strong class='text-gray-200'>Time out gracefully</strong> — If the caller doesn't press anything, don't just replay the menu. Offer to connect them with an agent."}}],["$","div","15",{"className":"h-2"}],["$","h2","16",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"Building an IVR with Asterisk Dialplan"}],["$","div","17",{"className":"h-2"}],["$","p","18",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Asterisk uses a dialplan in <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>/etc/asterisk/extensions.conf</code>. Here's a basic IVR:"}}],["$","div","19",{"className":"h-2"}],["$","pre","51",{"className":"bg-gray-900 border border-gray-800 rounded-xl p-4 overflow-x-auto my-6","children":["$","code",null,{"className":"text-sm text-gray-300 font-mono leading-relaxed","children":"[ivr-main]\n; Answer the call\nexten => s,1,Answer()\nsame => n,Wait(1)\n\n; Play the main menu greeting\nsame => n,Background(ivr/main-menu)\nsame => n,WaitExten(5)\n\n; Timeout — offer agent\nexten => t,1,Goto(agent-queue,s,1)\n\n; Invalid input\nexten => i,1,Playback(ivr/invalid-option)\nsame => n,Goto(ivr-main,s,3)\n\n; Option 1: Sales\nexten => 1,1,Playback(ivr/connecting-sales)\nsame => n,Goto(sales-queue,s,1)\n\n; Option 2: Support\nexten => 2,1,Playback(ivr/connecting-support)\nsame => n,Goto(support-queue,s,1)\n\n; Option 3: Billing\nexten => 3,1,Playback(ivr/connecting-billing)\nsame => n,Goto(billing-queue,s,1)\n\n; Option 0: Agent\nexten => 0,1,Goto(agent-queue,s,1)"}]}],["$","div","52",{"className":"h-2"}],["$","p","53",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>Background()</code> application plays a sound file while listening for DTMF input. <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>WaitExten(5)</code> gives the caller 5 seconds to press a key before triggering the timeout extension."}}],["$","div","54",{"className":"h-2"}],["$","h3","55",{"className":"text-xl font-semibold text-white mt-8 mb-3","children":"Recording Prompts"}],["$","div","56",{"className":"h-2"}],["$","p","57",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Record prompts at 8kHz, 16-bit mono (the native format for PSTN calls):"}}],["$","div","58",{"className":"h-2"}],["$","pre","62",{"className":"bg-gray-900 border border-gray-800 rounded-xl p-4 overflow-x-auto my-6","children":["$","code",null,{"className":"text-sm text-gray-300 font-mono leading-relaxed","children":"# Using SoX to convert a studio recording to Asterisk format\nsox input.wav -r 8000 -c 1 -e signed-integer -b 16 output.wav"}]}],["$","div","63",{"className":"h-2"}],["$","p","64",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Place recordings in <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>/var/lib/asterisk/sounds/ivr/</code>. Reference them without the extension in the dialplan: <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>Background(ivr/main-menu)</code> plays <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>/var/lib/asterisk/sounds/ivr/main-menu.wav</code>."}}],["$","div","65",{"className":"h-2"}],["$","h2","66",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"Building an IVR with FreeSWITCH"}],["$","div","67",{"className":"h-2"}],["$","p","68",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"FreeSWITCH uses Lua, JavaScript, or XML macros for IVR logic. Here's a Lua IVR script:"}}],["$","div","69",{"className":"h-2"}],["$","pre","98",{"className":"bg-gray-900 border border-gray-800 rounded-xl p-4 overflow-x-auto my-6","children":["$","code",null,{"className":"text-sm text-gray-300 font-mono leading-relaxed","children":"-- /usr/share/freeswitch/scripts/ivr_main.lua\n\nsession:answer()\nsession:sleep(1000)\n\nlocal choice = session:playAndGetDigits(\n  1,           -- min digits\n  1,           -- max digits\n  3,           -- max tries\n  5000,        -- timeout (ms)\n  \"#\",         -- terminator\n  \"ivr/main-menu\",  -- prompt file\n  \"ivr/invalid-option\",  -- bad input file\n  \"1-3|0\"      -- valid digits regex\n)\n\nif choice == \"1\" then\n  session:transfer(\"sales_queue\", \"XML\", \"default\")\nelseif choice == \"2\" then\n  session:transfer(\"support_queue\", \"XML\", \"default\")\nelseif choice == \"3\" then\n  session:transfer(\"billing_queue\", \"XML\", \"default\")\nelseif choice == \"0\" then\n  session:transfer(\"agent_queue\", \"XML\", \"default\")\nelse\n  session:transfer(\"agent_queue\", \"XML\", \"default\")\nend"}]}],["$","div","99",{"className":"h-2"}],["$","p","100",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>playAndGetDigits</code> handles the prompt playback, retry logic, and input collection in one call — simpler than the equivalent Asterisk dialplan."}}],["$","div","101",{"className":"h-2"}],["$","h2","102",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"Building an IVR with Twilio"}],["$","div","103",{"className":"h-2"}],["$","p","104",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Twilio uses TwiML (XML) served from your web endpoint. When a call arrives, Twilio makes an HTTP request to your URL and executes the TwiML response:"}}],["$","div","105",{"className":"h-2"}],["$","pre","121",{"className":"bg-gray-900 border border-gray-800 rounded-xl p-4 overflow-x-auto my-6","children":["$","code",null,{"className":"text-sm text-gray-300 font-mono leading-relaxed","children":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Response>\n  <Gather numDigits=\"1\" action=\"/ivr/handle-input\" timeout=\"5\">\n    <Say voice=\"Polly.Joanna\">\n      Thank you for calling Voxmation. \n      For sales, press 1. \n      For support, press 2. \n      For billing, press 3. \n      To speak with an agent, press 0.\n    </Say>\n  </Gather>\n  <!-- No input fallback -->\n  <Redirect>/ivr/agent</Redirect>\n</Response>"}]}],["$","div","122",{"className":"h-2"}],["$","p","123",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Your <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>/ivr/handle-input</code> endpoint receives the <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>Digits</code> POST parameter and returns the appropriate TwiML:"}}],["$","div","124",{"className":"h-2"}],["$","pre","146",{"className":"bg-gray-900 border border-gray-800 rounded-xl p-4 overflow-x-auto my-6","children":["$","code",null,{"className":"text-sm text-gray-300 font-mono leading-relaxed","children":"// Express.js handler\napp.post('/ivr/handle-input', (req, res) => {\n  const digit = req.body.Digits;\n  const queueMap = {\n    '1': 'sales',\n    '2': 'support',\n    '3': 'billing',\n    '0': 'agent',\n  };\n  \n  const queue = queueMap[digit] || 'agent';\n  \n  res.type('text/xml');\n  res.send(`\n    <?xml version=\"1.0\" encoding=\"UTF-8\"?>\n    <Response>\n      <Enqueue>${queue}</Enqueue>\n    </Response>\n  `);\n});"}]}],["$","div","147",{"className":"h-2"}],["$","h2","148",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"Adding Speech Recognition to Your IVR"}],["$","div","149",{"className":"h-2"}],["$","p","150",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"DTMF-only IVRs frustrate mobile callers who are driving or have accessibility needs. Adding speech recognition lets callers say their intent instead of pressing keys."}}],["$","div","151",{"className":"h-2"}],["$","p","152",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"With Twilio, add the <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>input</code> attribute to <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'><Gather></code>:"}}],["$","div","153",{"className":"h-2"}],["$","pre","158",{"className":"bg-gray-900 border border-gray-800 rounded-xl p-4 overflow-x-auto my-6","children":["$","code",null,{"className":"text-sm text-gray-300 font-mono leading-relaxed","children":"<Gather input=\"speech dtmf\" numDigits=\"1\" action=\"/ivr/handle-input\" timeout=\"5\" speechTimeout=\"auto\">\n  <Say>How can I help you today? You can say Sales, Support, or Billing — or press 1, 2, or 3.</Say>\n</Gather>"}]}],["$","div","159",{"className":"h-2"}],["$","p","160",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>SpeechResult</code> POST parameter will contain the transcribed input alongside <code class='bg-gray-900 text-violet-300 px-1.5 py-0.5 rounded text-sm font-mono'>Digits</code>."}}],["$","div","161",{"className":"h-2"}],["$","h2","162",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"Connecting Your IVR to a CRM"}],["$","div","163",{"className":"h-2"}],["$","p","164",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The most valuable IVR integration is CRM screen-pop: when an inbound call arrives, look up the caller's number, retrieve their account, and surface it to the agent before they pick up."}}],["$","div","165",{"className":"h-2"}],["$","p","166",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"With Asterisk AGI:"}}],["$","pre","191",{"className":"bg-gray-900 border border-gray-800 rounded-xl p-4 overflow-x-auto my-6","children":["$","code",null,{"className":"text-sm text-gray-300 font-mono leading-relaxed","children":"#!/usr/bin/env python3\nimport sys, requests\n\nagi_vars = {}\nfor line in sys.stdin:\n    line = line.strip()\n    if not line:\n        break\n    key, _, value = line.partition(': ')\n    agi_vars[key] = value\n\ncaller_id = agi_vars.get('agi_callerid', '')\nresp = requests.get(\n    f'https://your-crm/v1/contacts/search?phone={caller_id}',\n    headers={'Authorization': 'Bearer API_KEY'},\n    timeout=2\n)\n\nif resp.ok:\n    contact = resp.json()\n    print(f'SET VARIABLE CONTACT_NAME {contact[\"name\"]}')\n    print(f'SET VARIABLE CONTACT_ID {contact[\"id\"]}')\n    sys.stdout.flush()"}]}],["$","div","192",{"className":"h-2"}],["$","p","193",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"With Twilio, make a server-side API call in your TwiML webhook handler before returning the response."}}],["$","div","194",{"className":"h-2"}],["$","h2","195",{"className":"text-2xl font-bold text-white mt-10 mb-4","children":"Common IVR Mistakes to Avoid"}],["$","div","196",{"className":"h-2"}],["$","p","197",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"1. <strong class='text-gray-200'>No timeout handling</strong> — Always handle the case where the caller doesn't press anything."}}],["$","p","198",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"2. <strong class='text-gray-200'>Too many options</strong> — More than 5 options per level, and callers start hanging up."}}],["$","p","199",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"3. <strong class='text-gray-200'>Long intros</strong> — \"Thank you for calling Voxmation, a leader in voice prompt automation solutions\" wastes 8 seconds. Say \"Thank you for calling Voxmation\" and get to the menu."}}],["$","p","200",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"4. <strong class='text-gray-200'>Dead ends</strong> — Every path should either complete the customer's goal or route to an agent. No dead ends."}}],["$","p","201",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"5. <strong class='text-gray-200'>No error recovery</strong> — After invalid input, play \"I didn't catch that\" and try again — up to 3 times. Then route to an agent."}}],["$","p","202",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"6. <strong class='text-gray-200'>Using TTS for all prompts</strong> — TTS has improved dramatically but still sounds robotic for key messages. Record a human voice for your greeting. Use TTS for dynamic content (account numbers, appointment times)."}}],["$","div","203",{"className":"h-2"}],["$","p","204",{"className":"text-gray-400 leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"A well-built IVR handles the majority of inbound calls without a live agent, reduces hold times, and improves caller satisfaction. The technology is proven — the results depend entirely on the call flow design and prompt quality."}}]]}],["$","div",null,{"className":"mt-16 p-6 bg-gray-900/40 border border-violet-500/20 rounded-2xl","children":[["$","h3",null,{"className":"font-bold text-white mb-2","children":"Ready to automate your voice interactions?"}],["$","p",null,{"className":"text-gray-400 text-sm mb-4","children":"Voxmation makes it easy to build IVR menus, appointment reminders, and outbound campaigns — on your infrastructure or ours."}],["$","div",null,{"className":"flex flex-wrap gap-3","children":[["$","$L2",null,{"href":"/contact","className":"px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-se